NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Usada somente em rotas server-side para o admin criar usuarios no Supabase Auth.
# Nunca exponha essa chave no browser.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: endpoint server-side para enviar avisos de estoque por WhatsApp/API.
# Quando vazio, o painel continua com disparo manual por WhatsApp.
WHATSAPP_NOTIFY_ENDPOINT=
WHATSAPP_NOTIFY_TOKEN=
